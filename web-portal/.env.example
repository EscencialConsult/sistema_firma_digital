# ─────────────────────────────────────────────────────────────────────
# FIRMA DIGITAL PORTAL — Variables de entorno
# Copiá este archivo como: .env.local  (nunca subir .env.local a git)
# ─────────────────────────────────────────────────────────────────────

# Nombre de la app (solo visual)
VITE_APP_NAME=Firma Digital — Escencial

# ── Supabase ──────────────────────────────────────────────────────────
# Obtené estos valores en: Supabase Dashboard → Settings → API

# URL de tu proyecto Supabase
# Formato: https://xxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=https://TU_PROJECT_REF.supabase.co

# Anon/public key (segura para exponer en frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.TU_ANON_KEY_ACA

# ── Backend Express (dejar en blanco si solo usás Supabase directo) ──
# VITE_API_URL=http://localhost:4000/api
